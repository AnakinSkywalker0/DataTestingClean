# Unity text asset normalization
* text=auto eol=lf
*.cs text eol=lf
*.shader text eol=lf
*.mat text eol=lf
*.prefab text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.meta text eol=lf

# Git LFS — large binary assets
*.fbx filter=lfs diff=lfs merge=lfs -text
